# Copy this file to ".env" for local development (this filename is
# git-ignored) and fill in real values. For deployed environments, set the
# SAME variable names in the Vercel dashboard instead:
#   Vercel Project -> Settings -> Environment Variables
# Never put real values in this file, and never commit a real ".env".

# ---- Firebase Admin SDK (SERVER-SIDE ONLY) ----
# Source: Firebase Console -> Project Settings -> Service Accounts ->
# "Generate new private key". These must only ever be read inside a
# serverless/API function (e.g. an /api/*.js file on Vercel) — never
# referenced from any file loaded by the browser (index.html, shared.js,
# home.js, etc.).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# The downloaded JSON's "private_key" field contains literal "\n" sequences.
# Paste it as one line exactly as-is; when reading it in code, do:
#   process.env.FIREBASE_PRIVATE_KEY.replace(/\\n/g, "\n")
FIREBASE_PRIVATE_KEY=

# ---- Firebase Web app config (safe for client-side use) ----
# Source: Firebase Console -> Project Settings -> General -> Your apps ->
# SDK setup and configuration. This is a public identifier, not a secret —
# Firestore/Auth access is controlled by Security Rules, not by hiding this.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
